# App
ORIGIN="http://localhost:5173"
BETTER_AUTH_URL="http://localhost:5173"
ALLOWED_ORIGINS="quran.bid,localhost"

# Better Auth — use 32+ high-entropy chars in production
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Database
# Local Docker (run: docker compose up -d):
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/quran"
# Cloud Neon:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Internal proxy signature token (shared between server routes)
PROXY_SIGNATURE_TOKEN=""

# Quran Foundation Content API (client_credentials)
QF_CLIENT_ID=""
QF_CLIENT_SECRET=""
QF_OAUTH_URL="https://oauth2.quran.foundation"

# Quran Foundation User API (Quran.com OAuth login)
# Use pre-live client for local dev (has localhost:5173 redirect registered)
QF_USER_CLIENT_ID=""
QF_USER_CLIENT_SECRET=""
QF_USER_OAUTH_URL="https://prelive-oauth2.quran.foundation"
QF_USER_API_URL="https://apis-prelive.quran.foundation"
# Production:
# QF_USER_OAUTH_URL="https://oauth2.quran.foundation"
# QF_USER_API_URL="https://apis.quran.foundation"

# External URLs
API_GATEWAY_URL="https://apis.quran.foundation"
PUBLIC_EMBED_URL="https://quran.com/embed/v1"
PUBLIC_QURAN_REFLECT_URL="https://quranreflect.com"
